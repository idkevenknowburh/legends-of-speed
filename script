Tabs.Home:AddToggle({
    Title       = "Auto Hoops",
    Description = "Teleports all hoops to your position",
    Default     = false,
    Callback    = function(on)
        stopFarm("hoops")
        if on then
            farmThreads["hoops"] = true
            spawn(function()
                while farmThreads["hoops"] == true do
                    task.wait()
                    if farmThreads["hoops"] == true then
                        local char = player.Character
                        if char and char:FindFirstChild("HumanoidRootPart") then
                            local hrp = char.HumanoidRootPart
