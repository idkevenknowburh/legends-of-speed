-- ========== SERVICES ==========
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local RS = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer
local DiscordLink = "https://discord.gg/ZE6vyxgydK"

-- ========== THREAD MANAGEMENT ==========
local farmThreads = {}

local function stopFarm(name)
    farmThreads[name] = false
end

-- ========== FLUENT UI ==========
local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title       = "Legends of Speed | Sheitsa Hub V2",
    SubTitle    = "by Sheitsa",
    TabWidth    = 120,
    Size        = UDim2.fromOffset(550, 420),
    Acrylic     = true,
    Theme       = "Amoled",
    MinimizeKey = Enum.KeyCode.RightControl,
    ConfigurationSaving = {
        Enabled = false,
    },
})

local Tabs = {
    Home      = Window:AddTab({ Title = "Home",      Icon = "home" }),
    Pets      = Window:AddTab({ Title = "Pets",      Icon = "sparkles" }),
    Teleports = Window:AddTab({ Title = "Teleports", Icon = "map-pin" }),
    Credits   = Window:AddTab({ Title = "Credits",   Icon = "heart" }),
}

-- ==========================================
--  HOME TAB (Auto-Farm)
-- ==========================================
Tabs.Home:AddSection("Auto-Farm")

Tabs.Home:AddToggle({
    Title       = "Auto Orbs",
    Description = "Collects all orbs in the city",
    Default     = false,
    Callback    = function(on)
        stopFarm("orbs")
        if on then
            farmThreads["orbs"] = true
            spawn(function()
                while farmThreads["orbs"] == true do
                    task.wait()
                    if farmThreads["orbs"] == true then
                        local char = player.Character
                        if char and char:FindFirstChild("HumanoidRootPart") then
                            local hrp = char.HumanoidRootPart
                            local orbFolder = workspace:FindFirstChild("orbFolder")
                            if orbFolder then
                                local city = orbFolder:FindFirstChild("City")
                                if city then
                                    for _, v in pairs(city:GetChildren()) do
                                        if farmThreads["orbs"] == true and v.Name ~= "Gem" and v:FindFirstChild("outerOrb") then
                                            v.outerOrb.CFrame = hrp.CFrame
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        end
    end
})

Tabs.Home:AddToggle({
    Title       = "Auto Steps",
    Description = "Fires orb event for steps every 0.5s",
    Default     = false,
    Callback    = function(on)
        stopFarm("steps")
        if on then
            farmThreads["steps"] = true
            spawn(function()
                while farmThreads["steps"] == true do
                    task.wait(0.5)
                    if farmThreads["steps"] == true then
                        local rEvents = RS:FindFirstChild("rEvents")
                        if rEvents then
                            local ev = rEvents:FindFirstChild("orbEvent")
                            if ev then ev:FireServer("collectOrb", "Orange Orb", "City") end
                        end
                    end
                end
            end)
        end
    end
})

Tabs.Home:AddToggle({
    Title       = "Auto Rebirths",
    Description = "Requests rebirth every 5 seconds",
    Default     = false,
    Callback    = function(on)
        stopFarm("rebirths")
        if on then
            farmThreads["rebirths"] = true
            spawn(function()
                while farmThreads["rebirths"] == true do
                    task.wait(5)
                    if farmThreads["rebirths"] == true then
                        local rEvents = RS:FindFirstChild("rEvents")
                        if rEvents then
                            local ev = rEvents:FindFirstChild("rebirthEvent")
                            if ev then ev:FireServer("rebirthRequest") end
                        end
                    end
                end
            end)
        end
    end
})

Tabs.Home:AddToggle({
    Title       = "Auto Gems",
