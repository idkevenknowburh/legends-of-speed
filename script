tStroke.Color = Color3.fromRGB(190, 190, 200)
tStroke.Thickness = 1.5
tStroke.Parent = toggleBtn

-- Drag + Click toggle (5px threshold)
local tbDrag = false
local tbDragStart = Vector3.new(0, 0, 0)
local tbStartPos = UDim2.new()
local tbDidDrag = false

toggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        tbDrag = true
        tbDidDrag = false
        tbDragStart = input.Position
        tbStartPos = toggleBtn.Position
    end
end)

toggleBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if not tbDidDrag then
            gui.Enabled = not gui.Enabled
        end
        tbDrag = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if tbDrag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local d = input.Position - tbDragStart
        if math.abs(d.X) > 5 or math.abs(d.Y) > 5 then
            tbDidDrag = true
        end
        toggleBtn.Position = UDim2.new(
            tbStartPos.X.Scale, tbStartPos.X.Offset + d.X,
            tbStartPos.Y.Scale, tbStartPos.Y.Offset + d.Y
        )
    end
end)

