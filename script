-- ========== TWEEN HELPER ==========
local function tw(obj, props, dur)
    local info = TweenInfo.new(dur or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

