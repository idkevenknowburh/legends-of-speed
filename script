local function hideMain()
    mainVisible = false
    tw(main, {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1}, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
    task.delay(0.3, function()
        main.Visible = false
        toggleBtn.Visible = true
        tIcon.Text = "LS"
        tStroke.Color = Color3.fromRGB(190, 190, 200)
        toggleBtn.BackgroundColor3 = Color3.fromRGB(12, 12, 16)
    end)
end

local function showMain()
    mainVisible = true
    toggleBtn.Visible = false
    main.Visible = true
    main.Size = UDim2.new(0, 0, 0, 0)
    main.BackgroundTransparency = 1
    tw(main, {Size = UDim2.new(0, 420, 0, 500), BackgroundTransparency = 0.03}, 0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

