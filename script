activeTab = tabNames[1]

local function switchTab(name)
    if activeTab == name then return end
    -- Hide old tab
    tabPages[activeTab].Visible = false
    tabIndicators[activeTab].Visible = false
    tabButtons[activeTab].BackgroundTransparency = 1
    tabButtons[activeTab].TextColor3 = C.TextSub
    -- Show new tab
    activeTab = name
    tabPages[name].Visible = true
    tabIndicators[name].Visible = true
    tabButtons[name].BackgroundTransparency = 0
    tabButtons[name].BackgroundColor3 = C.CardHover
    tabButtons[name].TextColor3 = C.Text
    -- Scroll to top
    contentArea.CanvasPosition = Vector2.new(0, 0)
end

for _, name in ipairs(tabNames) do
    tabButtons[name].MouseButton1Click:Connect(function()
        switchTab(name)
    end)
end

