                            end
                        end
                    end
                end
            end)
        end
    end
})

-- ==========================================
--  PETS TAB
-- ==========================================
Tabs.Pets:AddSection("OP Pets")

Tabs.Pets:AddToggle({
    Title       = "Inf Glitch Pet",
    Description = "Spams rebirths + yellow orbs for infinite pets",
    Default     = false,
    Callback    = function(on)
        stopFarm("glitchPet")
        if on then
            farmThreads["glitchPet"] = true

            -- Thread 1: Rebirth spam
            spawn(function()
                while farmThreads["glitchPet"] == true do
                    task.wait()
                    if farmThreads["glitchPet"] == true then
                        local rEvents = RS:FindFirstChild("rEvents")
                        if rEvents then
                            local ev = rEvents:FindFirstChild("rebirthEvent")
                            if ev then ev:FireServer("rebirthRequest") end
                        end
                    end
                end
            end)

            -- Thread 2: Yellow orb spam (40 fires every 0.1s)
            spawn(function()
                while farmThreads["glitchPet"] == true do
                    task.wait(0.1)
                    if farmThreads["glitchPet"] == true then
                        local rEvents = RS:FindFirstChild("rEvents")
                        if rEvents then
                            local ev = rEvents:FindFirstChild("orbEvent")
                            if ev then
                                for _ = 1, 40 do
                                    if farmThreads["glitchPet"] == true then
                                        ev:FireServer("collectOrb", "Yellow Orb", "City")
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        end
    end
})

Tabs.Pets:AddButton({
    Title       = "Unlock Swift Samurai",
    Description = "Unlocks Swift Samurai pet",
    Callback    = function()
        local petShop = RS:FindFirstChild("cPetShopFolder")
        local petShopRemote = RS:FindFirstChild("cPetShopRemote")
        if petShop and petShopRemote then
            local swiftSamurai = petShop:FindFirstChild("Swift Samurai")
            if swiftSamurai then
                petShopRemote:InvokeServer(swiftSamurai)
            end
        end
    end
})

